# Address Data System Configuration
# 地址数据系统配置文件

# ==================== Proxy Configuration ====================
# 代理配置

# 方式 1: 直接使用完整的代理 URL
# PROXY_URL=http://username:password@proxy.example.com:10000

# 方式 2: 分别指定代理组件
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_HOST=res.proxy-seller.com
PROXY_PORT=10000

# ==================== API Configuration ====================
# API 配置

# API 请求超时时间（秒）
API_TIMEOUT=15

# 最大重试次数
MAX_RETRIES=3

# 重试延迟（秒）
RETRY_DELAY=1

# ==================== Output Configuration ====================
# 输出配置

# 输出目录（相对于项目根目录）
OUTPUT_DIR=./data

# ==================== Feature Flags ====================
# 功能开关

# 启用代理（如果代理信息不完整，自动关闭）
USE_PROXY=true

# 启用数据验证
VALIDATE_DATA=true

# ==================== Development ====================
# 开发配置

# 调试模式
DEBUG=false

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
